# Telegram bot token/chat id per repo-instance
HERMUX_BOT_TOKEN_SAMPLE=
HERMUX_ALLOWED_CHAT_ID_SAMPLE=

# Optional runtime tuning
HERMUX_STREAM_FLUSH_MS=1500
HERMUX_STREAM_CHUNK_BYTES=3000
HERMUX_MAX_PROCESS_SECONDS=3600
HERMUX_SERVE_READY_TIMEOUT_MS=15000

# Serve daemon port randomization (safe local range)
HERMUX_SERVE_PORT_RANGE_MIN=43100
HERMUX_SERVE_PORT_RANGE_MAX=43999
HERMUX_SERVE_PORT_PICK_ATTEMPTS=60

# Serve daemon lock and stale recovery tuning
HERMUX_SERVE_LOCK_WAIT_TIMEOUT_MS=12000
HERMUX_SERVE_LOCK_STALE_MS=30000
HERMUX_SERVE_LOCK_LEASE_RENEW_MS=2500
HERMUX_SERVE_LOCK_RETRY_MIN_MS=80
HERMUX_SERVE_LOCK_RETRY_MAX_MS=220
